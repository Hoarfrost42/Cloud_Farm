{
  "name": "cloud-island",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "preview": "vite preview --host 127.0.0.1",
    "desktop:dev": "npm run build && electron .",
    "package:desktop": "npm run build && electron-builder --dir",
    "simulate:weather": "node scripts/simulate-weather-reactor.mjs",
    "simulate:weather-strategies": "node scripts/simulate-weather-strategies.mjs"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "devDependencies": {
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "io.cloudisland.revival",
    "productName": "CloudIsland",
    "npmRebuild": false,
    "asar": true,
    "directories": {
      "output": "release-desktop"
    },
    "files": [
      "electron/main.cjs",
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
